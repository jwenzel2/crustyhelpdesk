generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String
  email        String   @unique
  passwordHash String?
  role         String   @default("TECHNICIAN") // ADMIN | TECHNICIAN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tickets     Ticket[]
}

model Ticket {
  id             String   @id @default(cuid())
  title          String
  description    String
  clientMachine  String
  status         String   @default("OPEN") // OPEN | IN_PROGRESS | AWAITING_LOGS | RESOLVED | CLOSED
  issueTimeStart DateTime
  issueTimeEnd   DateTime
  reportedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  logRequests LogRequest[]
}

model LogRequest {
  id             String   @id @default(cuid())
  status         String   @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | FAILED
  logType        String   // Application | System | Security | Setup
  timeRangeStart DateTime
  timeRangeEnd   DateTime
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  logEntries LogEntry[]
}

model LogEntry {
  id        String   @id @default(cuid())
  eventId   Int
  level     String
  source    String
  message   String
  timestamp DateTime
  rawXml    String?
  createdAt DateTime @default(now())

  logRequestId String
  logRequest   LogRequest @relation(fields: [logRequestId], references: [id])
}
