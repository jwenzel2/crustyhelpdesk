generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String
  email        String   @unique
  passwordHash String?
  phoneNumber  String?
  jobRole      String?
  avatarUrl    String?
  role         String   @default("CLIENT") // CLIENT | LEVEL_1 | LEVEL_2 | LEVEL_3 | ADMIN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tickets         Ticket[]  @relation("CreatedBy")
  assignedTickets Ticket[]  @relation("AssignedTo")
  comments        Comment[]
}

model Ticket {
  id              String   @id @default(cuid())
  title           String
  description     String
  clientMachine   String
  status          String   @default("OPEN") // OPEN | IN_PROGRESS | AWAITING_LOGS | ESCALATED | RESOLVED | CLOSED
  priority        String   @default("MEDIUM") // LOW | MEDIUM | HIGH
  escalationLevel Int      @default(1) // 1 = L1, 2 = L2, 3 = L3
  issueTimeStart  DateTime
  issueTimeEnd    DateTime
  reportedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?  @relation("AssignedTo", fields: [assignedToId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  logRequests LogRequest[]
  comments    Comment[]

  @@index([createdById])
  @@index([assignedToId])
  @@index([escalationLevel])
  @@index([categoryId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tickets   Ticket[]
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  authorId String?
  author   User?  @relation(fields: [authorId], references: [id])

  @@index([ticketId])
}

model LogRequest {
  id             String   @id @default(cuid())
  status         String   @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | FAILED
  logType        String   // Application | System | Security | Setup
  machineName    String   // copied from ticket.clientMachine when request is created
  timeRangeStart DateTime
  timeRangeEnd   DateTime
  errorMessage   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  logEntries LogEntry[]

  @@index([ticketId])
  @@index([machineName, status])
}

model AgentToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  machineName String
  description String?
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([machineName])
}

model LogEntry {
  id        String   @id @default(cuid())
  eventId   Int
  level     String
  source    String
  message   String
  timestamp DateTime
  rawXml    String?
  createdAt DateTime @default(now())

  logRequestId String
  logRequest   LogRequest @relation(fields: [logRequestId], references: [id])

  @@index([logRequestId])
}

model SiteSettings {
  id    String @id @default("singleton")
  key   String @unique
  value String
}
